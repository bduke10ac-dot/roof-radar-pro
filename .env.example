# Copy to .env and fill in values. Do NOT commit .env.

# --- Lovable Cloud / Supabase (frontend) ---
VITE_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-publishable-key"
VITE_SUPABASE_PROJECT_ID="your-project-ref"

# --- Stripe (publishable key only — safe in frontend) ---
# Use pk_test_... in .env.development and pk_live_... in .env.production
VITE_PAYMENTS_CLIENT_TOKEN="pk_test_xxx"

# =====================================================================
# Backend / edge function secrets — set in Supabase dashboard, NOT here
# =====================================================================
# SUPABASE_URL
# SUPABASE_SERVICE_ROLE_KEY
# STRIPE_SANDBOX_API_KEY
# STRIPE_LIVE_API_KEY
# PAYMENTS_SANDBOX_WEBHOOK_SECRET
# PAYMENTS_LIVE_WEBHOOK_SECRET
# LOVABLE_API_KEY                  # for Lovable AI Gateway (optional)
#
# Optional integrations (only if you wire them up):
# GOOGLE_MAPS_API_KEY              # geocoding / maps
# OPENWEATHER_API_KEY              # weather feed
# NOAA_API_KEY                     # storm/weather feed (NWS is keyless)
# TWILIO_ACCOUNT_SID / TWILIO_AUTH_TOKEN / TWILIO_FROM_NUMBER
# SENDGRID_API_KEY / SENDGRID_FROM_EMAIL
# ATTOM_API_KEY / ESTATED_API_KEY / REGRID_API_KEY
